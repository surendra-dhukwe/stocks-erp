USE stockerp;

CREATE TABLE products (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100),
  weight_per_bag FLOAT,
  price_per_bag FLOAT
);

CREATE TABLE warehouses (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100)
);

INSERT INTO warehouses (name) VALUES ('Main Warehouse');

CREATE TABLE stock (
  id INT AUTO_INCREMENT PRIMARY KEY,
  product_id INT,
  warehouse_id INT,
  current_bags FLOAT DEFAULT 0
);

CREATE TABLE transactions (
  id INT AUTO_INCREMENT PRIMARY KEY,
  product_id INT,
  warehouse_id INT,
  bags FLOAT,
  type VARCHAR(20),
  negative_reason VARCHAR(255),
  total_weight FLOAT,
  total_amount FLOAT,
  date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

